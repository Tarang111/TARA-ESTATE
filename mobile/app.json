{
  "expo": {
    "name": "Tara Estate",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/newlogo.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
   "splash": {
      "image": "./assets/images/Gemini_Generated_Image_lxal65lxal65lxal.png",
      "resizeMode": "cover",
    "backgroundColor": "#E6F4FE"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/newlogo.png",
        "backgroundImage": "./assets/images/newlogo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.tarang1111.mobile"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./withPackagingOptions",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow  Tara to access your location to tag property coordinates."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Gemini_Generated_Image_lxal65lxal65lxal.png",
         
          "resizeMode": "cover",
         "backgroundColor": "#E6F4FE"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "afa5e4ca-03bd-44e6-b9f2-a6f4509c4021"
      }
    }
  }
}
